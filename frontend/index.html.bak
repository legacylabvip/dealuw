<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DealUW - Wholesaler Underwriting</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #1a1a1a;
            color: #fff;
        }
        
        .navbar {
            background: #0f0f0f;
            border-bottom: 1px solid #333;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .logo {
            font-size: 1.5rem;
            font-weight: bold;
            color: #ffd700;
        }
        
        .logo-text {
            font-size: 0.8rem;
            color: #999;
            margin-top: 0.2rem;
        }
        
        .nav-links a {
            color: #fff;
            text-decoration: none;
            margin-left: 2rem;
            transition: color 0.3s;
        }
        
        .nav-links a:hover {
            color: #ffd700;
        }
        
        .hero {
            background: linear-gradient(135deg, #4A235A 0%, #2d1b4e 100%);
            padding: 4rem 2rem;
            text-align: center;
        }
        
        .hero h1 {
            font-size: 3rem;
            margin-bottom: 1rem;
            color: #ffd700;
        }
        
        .hero p {
            font-size: 1.2rem;
            margin-bottom: 2rem;
            color: #ccc;
        }
        
        .btn {
            padding: 0.75rem 2rem;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .btn-primary {
            background: #ffd700;
            color: #000;
            font-weight: bold;
        }
        
        .btn-primary:hover {
            background: #ffed4e;
            transform: translateY(-2px);
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 3rem 2rem;
        }
        
        .underwriting-form {
            background: #2a2a2a;
            padding: 2rem;
            border-radius: 8px;
            margin: 2rem 0;
        }
        
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        label {
            display: block;
            margin-bottom: 0.5rem;
            color: #ffd700;
            font-weight: 600;
        }
        
        input, select {
            width: 100%;
            padding: 0.75rem;
            background: #1a1a1a;
            border: 1px solid #444;
            color: #fff;
            border-radius: 4px;
            font-size: 1rem;
        }
        
        input:focus, select:focus {
            outline: none;
            border-color: #ffd700;
            box-shadow: 0 0 0 2px rgba(255, 215, 0, 0.2);
        }
        
        .results {
            background: #2a2a2a;
            padding: 2rem;
            border-radius: 8px;
            margin-top: 2rem;
            display: none;
        }
        
        .results.active {
            display: block;
        }
        
        .offer-card {
            background: #333;
            padding: 1.5rem;
            border-radius: 8px;
            margin: 1rem 0;
            border-left: 4px solid #ffd700;
        }
        
        .offer-card h3 {
            color: #ffd700;
            margin-bottom: 0.5rem;
        }
        
        .offer-price {
            font-size: 2rem;
            font-weight: bold;
            color: #27AE60;
            margin: 1rem 0;
        }
        
        .profit-margin {
            color: #999;
            font-size: 0.9rem;
        }
        
        .pricing-section {
            background: #2a2a2a;
            padding: 3rem 2rem;
            text-align: center;
            margin: 3rem 0;
        }
        
        .pricing-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }
        
        .price-card {
            background: #333;
            padding: 2rem;
            border-radius: 8px;
            border: 2px solid #444;
            transition: all 0.3s;
        }
        
        .price-card:hover {
            border-color: #ffd700;
            transform: translateY(-5px);
        }
        
        .price-card h3 {
            color: #ffd700;
            margin-bottom: 1rem;
            font-size: 1.5rem;
        }
        
        .price {
            font-size: 2.5rem;
            font-weight: bold;
            color: #fff;
            margin: 1rem 0;
        }
        
        .price span {
            font-size: 1rem;
            color: #999;
        }
        
        .features {
            text-align: left;
            margin: 1.5rem 0;
            color: #ccc;
        }
        
        .features li {
            margin: 0.5rem 0;
            list-style: none;
            padding-left: 1.5rem;
            position: relative;
        }
        
        .features li:before {
            content: "✓";
            position: absolute;
            left: 0;
            color: #27AE60;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="navbar">
        <div>
            <div class="logo">DealUW</div>
            <div class="logo-text">dealuw.com</div>
        </div>
        <div class="nav-links">
            <a href="#home">Home</a>
            <a href="#underwrite">Underwrite</a>
            <a href="#pricing">Pricing</a>
            <a href="#discord">Discord Bot</a>
        </div>
    </div>
    
    <div class="hero">
        <h1>Forge Better Offers</h1>
        <p>Instant property underwriting for wholesalers. Cash, Novation, Subject-To strategies.</p>
        <button class="btn btn-primary" onclick="document.querySelector('.underwriting-form').scrollIntoView()">
            Start Free Trial
        </button>
    </div>
    
    <div class="container">
        <div class="underwriting-form">
            <h2 style="color: #ffd700; margin-bottom: 1.5rem;">Property Underwriting</h2>
            
            <form id="underwritingForm" onsubmit="handleUnderwrite(event)">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label>After-Repair Value (ARV)</label>
                        <input type="number" id="arv" placeholder="$300000" required>
                    </div>
                    
                    <div class="form-group">
                        <label>Repair Estimate</label>
                        <input type="number" id="repairs" placeholder="$40000" required>
                    </div>
                </div>
                
                <div class="form-group">
                    <label>Deal Type</label>
                    <select id="dealType">
                        <option value="cash">Cash Offer</option>
                        <option value="novation">Novation</option>
                        <option value="subject-to">Subject-To</option>
                    </select>
                </div>
                
                <button type="submit" class="btn btn-primary" style="width: 100%;">
                    Analyze Deal
                </button>
            </form>
        </div>
        
        <div id="results" class="results">
            <h2 style="color: #ffd700; margin-bottom: 1.5rem;">Offer Analysis</h2>
            
            <div class="offer-card">
                <h3>Conservative Offer</h3>
                <div class="offer-price" id="conservativePrice">—</div>
                <p class="profit-margin">Profit Margin: 25% | Buyer Type: Investor</p>
            </div>
            
            <div class="offer-card">
                <h3>Fair Offer (Recommended)</h3>
                <div class="offer-price" id="fairPrice">—</div>
                <p class="profit-margin">Profit Margin: 20% | Buyer Type: Active Wholesaler</p>
            </div>
            
            <div class="offer-card">
                <h3>Aggressive Offer</h3>
                <div class="offer-price" id="aggressivePrice">—</div>
                <p class="profit-margin">Profit Margin: 15% | Buyer Type: Cash Buyer</p>
            </div>
        </div>
    </div>
    
    <div class="pricing-section">
        <h2 style="color: #ffd700;">Subscription Plans</h2>
        
        <div class="pricing-cards">
            <div class="price-card">
                <h3>Free Trial</h3>
                <p>1 Week Access</p>
                <div class="price">Free<span>/week</span></div>
                <ul class="features">
                    <li>10 Property Analyses</li>
                    <li>Basic Underwriting</li>
                    <li>Email Support</li>
                </ul>
                <button class="btn btn-primary" style="width: 100%;">Start Trial</button>
            </div>
            
            <div class="price-card" style="border-color: #ffd700;">
                <h3>Pro</h3>
                <p>For Active Wholesalers</p>
                <div class="price">$99<span>/month</span></div>
                <ul class="features">
                    <li>Unlimited Analyses</li>
                    <li>Discord Bot Access</li>
                    <li>Deal Database</li>
                    <li>PDF Export</li>
                    <li>Priority Support</li>
                </ul>
                <button class="btn btn-primary" style="width: 100%;">Subscribe</button>
            </div>
            
            <div class="price-card">
                <h3>Elite</h3>
                <p>For Teams</p>
                <div class="price">$199<span>/month</span></div>
                <ul class="features">
                    <li>Everything in Pro</li>
                    <li>Strategy Calls (1/mo)</li>
                    <li>Custom Formulas</li>
                    <li>Team Collaboration</li>
                    <li>Lead Gen Tools</li>
                </ul>
                <button class="btn btn-primary" style="width: 100%;">Subscribe</button>
            </div>
        </div>
    </div>
    
    <script>
        async function handleUnderwrite(event) {
            event.preventDefault();
            
            const arv = parseInt(document.getElementById('arv').value);
            const repairs = parseInt(document.getElementById('repairs').value);
            const dealType = document.getElementById('dealType').value;
            
            try {
                const response = await fetch('http://localhost:5000/api/calculate/offer-analysis', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ arv, repairs })
                });
                
                const data = await response.json();
                
                document.getElementById('conservativePrice').textContent = 
                    '$' + data.offers.conservative.offerPrice.toLocaleString();
                document.getElementById('fairPrice').textContent = 
                    '$' + data.offers.fair.offerPrice.toLocaleString();
                document.getElementById('aggressivePrice').textContent = 
                    '$' + data.offers.aggressive.offerPrice.toLocaleString();
                
                document.getElementById('results').classList.add('active');
                document.getElementById('results').scrollIntoView({ behavior: 'smooth' });
            } catch (error) {
                alert('Error: ' + error.message);
            }
        }
    </script>
</body>
</html>
